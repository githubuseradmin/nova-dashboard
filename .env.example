# Copy to .env and adjust. .env is gitignored — never commit real secrets.

# Runtime
NOVA_ENV=development           # development | production
NOVA_HOST=0.0.0.0
NOVA_PORT=8080
NOVA_LOG_LEVEL=info            # debug | info | warn | error

# Database (matches docker-compose.yml defaults)
NOVA_DATABASE_URL=postgres://nova:nova@localhost:5432/nova?sslmode=disable

# Static assets served by Go (relative to the working directory).
# In dev you can ignore these and use the Vite dev server instead.
NOVA_SITE_DIR=web/site
NOVA_APP_DIR=web/app/dist

# Initial admin — seeded on first run only, when the users table is empty.
# Change these before running in production.
NOVA_ADMIN_EMAIL=admin@nova.local
NOVA_ADMIN_PASSWORD=admin12345
